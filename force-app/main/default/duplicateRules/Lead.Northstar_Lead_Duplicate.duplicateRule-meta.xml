<?xml version="1.0" encoding="UTF-8" ?>
<DuplicateRule
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
>
    <actionOnInsert>Allow</actionOnInsert>
    <actionOnUpdate>Allow</actionOnUpdate>
    <alertText
  >A Lead with the same email and company already exists. Review the matching record before creating a duplicate.</alertText>
    <description
  >Northstar Lead duplicate rule. Allow-with-alert on insert/update for Leads matching an existing Lead on Email+Company. Allow (not Block) because public Lead OWD makes same-owner-only blocking impossible.</description>
    <duplicateRuleFilter xsi:nil="true" />
    <duplicateRuleMatchRules>
        <matchRuleSObjectType>Lead</matchRuleSObjectType>
        <matchingRule>Northstar_Lead_Match</matchingRule>
        <objectMapping xsi:nil="true" />
    </duplicateRuleMatchRules>
    <isActive>true</isActive>
    <masterLabel>Northstar Lead Duplicate</masterLabel>
    <operationsOnInsert>Alert</operationsOnInsert>
    <operationsOnInsert>Report</operationsOnInsert>
    <operationsOnUpdate>Alert</operationsOnUpdate>
    <operationsOnUpdate>Report</operationsOnUpdate>
    <securityOption>EnforceSharingRules</securityOption>
    <sortOrder>1</sortOrder>
</DuplicateRule>
