<?xml version="1.0" encoding="UTF-8" ?>
<DuplicateRule
  xmlns="http://soap.sforce.com/2006/04/metadata"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
>
    <actionOnInsert>Allow</actionOnInsert>
    <actionOnUpdate>Allow</actionOnUpdate>
    <alertText
  >An Account with the same website and name already exists. Review the matching record before continuing.</alertText>
    <description
  >Northstar Account duplicate rule. Allow-with-alert on insert and update for Accounts that match an existing Account on Website+Name (Northstar_Account_Match).</description>
    <duplicateRuleFilter xsi:nil="true" />
    <duplicateRuleMatchRules>
        <matchRuleSObjectType>Account</matchRuleSObjectType>
        <matchingRule>Northstar_Account_Match</matchingRule>
        <objectMapping xsi:nil="true" />
    </duplicateRuleMatchRules>
    <isActive>true</isActive>
    <masterLabel>Northstar Account Duplicate</masterLabel>
    <operationsOnInsert>Alert</operationsOnInsert>
    <operationsOnInsert>Report</operationsOnInsert>
    <operationsOnUpdate>Alert</operationsOnUpdate>
    <operationsOnUpdate>Report</operationsOnUpdate>
    <securityOption>EnforceSharingRules</securityOption>
    <sortOrder>1</sortOrder>
</DuplicateRule>
