<?xml version="1.0" encoding="UTF-8"?>
<Dashboard xmlns="http://soap.sforce.com/2006/04/metadata">
    <backgroundEndColor>#FFFFFF</backgroundEndColor>
    <backgroundFadeDirection>Diagonal</backgroundFadeDirection>
    <backgroundStartColor>#FFFFFF</backgroundStartColor>
    <dashboardType>SpecifiedUser</dashboardType>
    <description>Renewal risk: activated contracts approaching renewal not yet handled by automation, plus open escalated cases. Static (SpecifiedUser) to stay within the DE cap of 3 dynamic dashboards; reports are org-scoped.</description>
    <isGridLayout>false</isGridLayout>
    <leftSection>
        <columnSize>Medium</columnSize>
        <components>
            <componentType>Metric</componentType>
            <header>Contracts Renewing in 90 Days</header>
            <indicatorHighColor>C254</indicatorHighColor>
            <indicatorLowColor>#C25454</indicatorLowColor>
            <indicatorMiddleColor>#D9C636</indicatorMiddleColor>
            <metricLabel>At-risk renewals</metricLabel>
            <report>Northstar_Pipeline/Contracts_Renewing_In_90_Days</report>
            <title>Contracts Renewing in 90 Days</title>
        </components>
    </leftSection>
    <rightSection>
        <columnSize>Medium</columnSize>
        <components>
            <componentType>Metric</componentType>
            <header>Open Renewal Escalations</header>
            <indicatorHighColor>C254</indicatorHighColor>
            <indicatorLowColor>#C25454</indicatorLowColor>
            <indicatorMiddleColor>#D9C636</indicatorMiddleColor>
            <metricLabel>Cases escalated to renewal queue</metricLabel>
            <report>Northstar_Customer_Success/Open_Escalated_Cases</report>
            <title>Open Renewal Escalations</title>
        </components>
    </rightSection>
    <runningUser>@@DASHBOARD_RUNNING_USER@@</runningUser>
    <textColor></textColor>
    <title>Northstar Renewal Risk</title>
    <titleColor></titleColor>
    <titleSize>12</titleSize>
</Dashboard>
