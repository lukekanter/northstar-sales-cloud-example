    <!-- Quicker Quotes: grant run access to the QQ entry flow
         and its first-run config subflow so the global launcher actually opens
         QQ_New_Quote2. Sales personas have no RunFlow and the org has no Flow
         User flag, so without this the flow won't start. Least-privilege
         flowAccesses (these two flows only), not blanket RunFlow. -->
    <flowAccesses>
        <enabled>true</enabled>
        <flow>QQ_Config_Settings_First_Run</flow>
    </flowAccesses>
    <flowAccesses>
        <enabled>true</enabled>
        <flow>QQ_New_Quote2</flow>
    </flowAccesses>
