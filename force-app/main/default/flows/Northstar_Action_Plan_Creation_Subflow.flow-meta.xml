<?xml version="1.0" encoding="UTF-8" ?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description
  >Northstar. Reusable subflow: given an Implementation Package and Customer Segment, reads Implementation_Playbook_Rule__mdt and returns the Action Plan template name and intended owner group. Matches the most specific rule first (exact package + segment), then falls back to a package-only rule (Segment blank = any). Sets outputMatched=false when no rule applies so callers can skip Action Plan creation. Called by Action_Plan_From_Closed_Won.</description>
    <environments>Default</environments>
    <assignments>
        <name>Assign_From_Any</name>
        <label>Assign From Any-Segment Rule</label>
        <locationX>50</locationX>
        <locationY>504</locationY>
        <assignmentItems>
            <assignToReference>outputTemplateName</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference
        >Get_AnySegment_Match.Action_Plan_Template__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>outputOwnerGroup</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference
        >Get_AnySegment_Match.Owner_Group__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>outputMatched</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
