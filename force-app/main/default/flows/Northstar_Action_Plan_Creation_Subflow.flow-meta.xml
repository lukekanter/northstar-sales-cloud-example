            <value>
                <elementReference
        >Get_Exact_Match.Owner_Group__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>outputMatched</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Assign_None</name>
        <label>Assign No Match</label>
        <locationX>314</locationX>
        <locationY>504</locationY>
        <assignmentItems>
            <assignToReference>outputMatched</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>AnySegment_Found</name>
        <label>Any-Segment Rule Found?</label>
        <locationX>176</locationX>
        <locationY>396</locationY>
        <defaultConnectorLabel>No Rule</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Assign_None</targetReference>
        </defaultConnector>
        <rules>
            <name>Has_Any_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_AnySegment_Match.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_From_Any</targetReference>
            </connector>
            <label>Any-Segment Rule Exists</label>
        </rules>
    </decisions>
    <decisions>
        <name>Exact_Found</name>
        <label>Exact Rule Found?</label>
        <locationX>176</locationX>
        <locationY>180</locationY>
        <defaultConnectorLabel>No Exact Rule</defaultConnectorLabel>
        <defaultConnector>
            <targetReference>Get_AnySegment_Match</targetReference>
        </defaultConnector>
        <rules>
            <name>Has_Exact_Rule</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Exact_Match.Id</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_From_Exact</targetReference>
            </connector>
            <label>Exact Rule Exists</label>
        </rules>
    </decisions>
    <interviewLabel
  >Northstar Action Plan Creation Subflow {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Northstar Action Plan Creation Subflow</label>
    <processType>AutoLaunchedFlow</processType>
    <recordLookups>
        <name>Get_AnySegment_Match</name>
        <label>Get Any-Segment Playbook Rule</label>
        <locationX>176</locationX>
        <locationY>288</locationY>
        <assignNullValuesIfNoRecordsFound
    >false</assignNullValuesIfNoRecordsFound>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Implementation_Package__c</field>
            <operator>EqualTo</operator>
