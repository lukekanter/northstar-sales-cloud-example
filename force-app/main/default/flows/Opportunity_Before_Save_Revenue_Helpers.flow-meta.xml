<?xml version="1.0" encoding="UTF-8" ?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>66.0</apiVersion>
    <description
  >Northstar. Before-save revenue helpers for Opportunities: raises Requires_Finance_Review__c when Amount crosses up to &gt;= 100,000 and Requires_Legal_Review__c when Amount crosses up to &gt;= 250,000. The flags are raised ONLY on the save where Amount crosses the threshold (new record at/above it, or a prior Amount below it) — never re-raised while the Amount merely stays above — so a reviewer can clear the flag after review and it stays cleared (the field help documents manual override). Flags are never cleared by this flow, so it additively overlaps the Amount-driven Apex path (OpportunityTriggerHandler) and the Quote-accepted path (Quote_After_Save_Accepted_Quote_Sync). NOTE: the spec's "ARR band" picklist (Opportunity.ARR_Band__c) is stamped by OpportunityTriggerHandler, NOT by this flow — it buckets ARR__c, which is recalculated in before-save Apex that runs AFTER before-save flows, so a flow stamp would bucket a stale ARR__c. The spec's implied writable "contract term helper" was dropped as redundant (Subscription_Term_Years__c already derives term-in-years).</description>
    <environments>Default</environments>
    <formulas>
        <name>FinanceCrossedUp</name>
        <dataType>Boolean</dataType>
        <expression
    >AND({!$Record.Amount} &gt;= 100000, OR(ISBLANK({!$Record__Prior.Amount}), {!$Record__Prior.Amount} &lt; 100000))</expression>
    </formulas>
    <formulas>
        <name>LegalCrossedUp</name>
        <dataType>Boolean</dataType>
        <expression
    >AND({!$Record.Amount} &gt;= 250000, OR(ISBLANK({!$Record__Prior.Amount}), {!$Record__Prior.Amount} &lt; 250000))</expression>
    </formulas>
    <decisions>
        <name>Finance_Threshold</name>
        <label>Amount at/above Finance threshold?</label>
        <locationX>176</locationX>
        <locationY>168</locationY>
        <defaultConnector>
            <targetReference>Legal_Threshold</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Over_Finance_Threshold</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>FinanceCrossedUp</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Finance_Review</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <decisions>
        <name>Legal_Threshold</name>
        <label>Amount at/above Legal threshold?</label>
        <locationX>176</locationX>
        <locationY>408</locationY>
        <defaultConnectorLabel>No</defaultConnectorLabel>
        <rules>
            <name>Over_Legal_Threshold</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>LegalCrossedUp</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Legal_Review</targetReference>
            </connector>
            <label>Yes</label>
        </rules>
    </decisions>
    <interviewLabel
  >Opportunity Before Save - Revenue Helpers {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Opportunity Before Save - Revenue Helpers</label>
    <processType>AutoLaunchedFlow</processType>
    <assignments>
        <name>Set_Finance_Review</name>
        <label>Raise Finance Review</label>
        <locationX>50</locationX>
        <locationY>288</locationY>
        <assignmentItems>
            <assignToReference
      >$Record.Requires_Finance_Review__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Legal_Threshold</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Set_Legal_Review</name>
        <label>Raise Legal Review</label>
        <locationX>50</locationX>
        <locationY>528</locationY>
        <assignmentItems>
            <assignToReference
      >$Record.Requires_Legal_Review__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </assignmentItems>
    </assignments>
    <start>
        <locationX>176</locationX>
        <locationY>48</locationY>
        <connector>
            <targetReference>Finance_Threshold</targetReference>
        </connector>
        <object>Opportunity</object>
        <recordTriggerType>CreateAndUpdate</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
