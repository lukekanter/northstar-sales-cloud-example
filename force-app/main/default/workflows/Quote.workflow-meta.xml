<?xml version="1.0" encoding="UTF-8" ?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Northstar_Quote_Discount_Approval_Alert</fullName>
        <description
    >Notifies Deal Desk when a Quote enters the Northstar Quote Discount Approval process.</description>
        <protected>false</protected>
        <recipients>
            <recipient>Northstar_Deal_Desk</recipient>
            <type>group</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Northstar_Approvals/Quote_Discount_Approval_Request</template>
    </alerts>
    <alerts>
        <fullName>Northstar_Non_Standard_Terms_Approval_Alert</fullName>
        <description
    >Notifies Legal Reviewers and Deal Desk when a Quote enters the Northstar Non-Standard Terms Approval process.</description>
        <protected>false</protected>
        <recipients>
            <recipient>Northstar_Legal_Reviewers</recipient>
            <type>group</type>
        </recipients>
        <recipients>
            <recipient>Northstar_Deal_Desk</recipient>
            <type>group</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template
    >Northstar_Approvals/Non_Standard_Terms_Approval_Request</template>
    </alerts>
    <alerts>
        <fullName>Northstar_Services_Margin_Approval_Alert</fullName>
        <description
    >Notifies Finance Reviewers when a Quote enters the Northstar Services Margin Approval process.</description>
        <protected>false</protected>
        <recipients>
            <recipient>Northstar_Finance_Reviewers</recipient>
            <type>group</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template
    >Northstar_Approvals/Services_Margin_Approval_Request</template>
    </alerts>
    <fieldUpdates>
        <fullName>Northstar_Quote_Discount_Status_Approved</fullName>
        <description
    >Final-approval writer for the discount dimension. Discount_Approval_Status__c is automation-only; this is the system-context writer.</description>
        <field>Discount_Approval_Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Northstar Quote Discount Status Approved</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Northstar_Quote_Discount_Status_Rejected</fullName>
        <description
    >Final-rejection writer for the discount dimension.</description>
        <field>Discount_Approval_Status__c</field>
        <literalValue>Rejected</literalValue>
        <name>Northstar Quote Discount Status Rejected</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
