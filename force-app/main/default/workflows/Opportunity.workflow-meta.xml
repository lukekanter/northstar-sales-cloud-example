<?xml version="1.0" encoding="UTF-8" ?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Northstar_Discount_Approval_Request_Alert</fullName>
        <description
    >Notifies the Deal Desk public group when an Opportunity enters the Northstar Discount Approval process.</description>
        <protected>false</protected>
        <recipients>
            <recipient>Northstar_Deal_Desk</recipient>
            <type>group</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>Northstar_Approvals/Discount_Approval_Request</template>
    </alerts>
    <fieldUpdates>
        <fullName>Northstar_Opp_Discount_Status_Approved</fullName>
        <description
    >Final-approval writer for the Opportunity discount dimension. Discount_Approval_Status__c is automation-only; this is the system-context writer that lets the Opp close won.</description>
        <field>Discount_Approval_Status__c</field>
        <literalValue>Approved</literalValue>
        <name>Northstar Opp Discount Status Approved</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Northstar_Opp_Discount_Status_Rejected</fullName>
        <description
    >Final-rejection writer for the Opportunity discount dimension.</description>
        <field>Discount_Approval_Status__c</field>
        <literalValue>Rejected</literalValue>
        <name>Northstar Opp Discount Status Rejected</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
</Workflow>
