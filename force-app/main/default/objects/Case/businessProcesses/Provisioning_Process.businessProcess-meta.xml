<?xml version="1.0" encoding="UTF-8" ?>
<BusinessProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Provisioning_Process</fullName>
    <description>Status flow for Provisioning Exception cases (raised by Provisioning_Completed__e Status='Failed'). Escalated path is used when SLA expires.</description>
    <isActive>true</isActive>
    <values>
        <fullName>New</fullName>
        <default>true</default>
    </values>
    <values>
        <fullName>In Progress</fullName>
        <default>false</default>
    </values>
    <values>
        <fullName>Escalated</fullName>
        <default>false</default>
    </values>
    <values>
        <fullName>Resolved</fullName>
        <default>false</default>
    </values>
    <values>
        <fullName>Closed</fullName>
        <default>false</default>
    </values>
</BusinessProcess>
