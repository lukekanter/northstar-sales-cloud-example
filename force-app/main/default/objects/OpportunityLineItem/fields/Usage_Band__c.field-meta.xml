<?xml version="1.0" encoding="UTF-8" ?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Usage_Band__c</fullName>
    <description
  >For Revenue_Type__c = 'Usage' line items: the committed-usage tier (Low, Mid, High, Custom). Used by the Usage Overage workflow to decide which Product2 (NS-USAGE-BLOCK) row gets billed at overage.</description>
    <inlineHelpText
  >Usage tier for usage-based line items. Ignored for non-usage line items.</inlineHelpText>
    <label>Usage Band</label>
    <required>false</required>
    <trackFeedHistory>false</trackFeedHistory>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Low</fullName>
                <default>false</default>
                <label>Low</label>
            </value>
            <value>
                <fullName>Mid</fullName>
                <default>false</default>
                <label>Mid</label>
            </value>
            <value>
                <fullName>High</fullName>
                <default>false</default>
                <label>High</label>
            </value>
            <value>
                <fullName>Custom</fullName>
                <default>false</default>
                <label>Custom</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
